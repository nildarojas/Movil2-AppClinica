<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:padding="24dp"
    tools:context=".CambiarPasswordInternoActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvTituloCambioInterno"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Seguridad de la Cuenta"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#458890"
            android:layout_gravity="center"
            android:layout_marginBottom="30dp"/>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Contraseña Actual"
            android:layout_marginBottom="16dp"
            app:boxStrokeColor="#458890"
            app:hintTextColor="#458890"
            app:passwordToggleEnabled="true"
            app:passwordToggleTint="#458890">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPasswordActual"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"/>

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nueva Contraseña"
            android:layout_marginBottom="16dp"
            app:boxStrokeColor="#458890"
            app:hintTextColor="#458890"
            app:passwordToggleEnabled="true"
            app:passwordToggleTint="#458890">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPasswordNueva1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"/>

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Confirmar Nueva Contraseña"
            android:layout_marginBottom="30dp"
            app:boxStrokeColor="#458890"
            app:hintTextColor="#458890"
            app:passwordToggleEnabled="true"
            app:passwordToggleTint="#458890">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPasswordNueva2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"/>

        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/btnActualizarPasswordInterno"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Actualizar Contraseña"
            android:backgroundTint="#458890"
            android:textSize="16sp"
            android:textStyle="bold"/>

    </LinearLayout>
</ScrollView>