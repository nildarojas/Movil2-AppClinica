<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Reprogramar Cita"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#458890"
        android:gravity="center"
        android:layout_marginBottom="32dp"/>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Seleccionar Nuevo Médico"
        android:layout_marginBottom="16dp"
        app:boxStrokeColor="#458890"
        app:hintTextColor="#458890">

        <AutoCompleteTextView
            android:id="@+id/acNuevoMedico"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="none"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Seleccionar Nuevo Horario"
        android:layout_marginBottom="32dp"
        app:boxStrokeColor="#458890"
        app:hintTextColor="#458890">

        <AutoCompleteTextView
            android:id="@+id/acNuevoHorario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="none"/>
    </com.google.android.material.textfield.TextInputLayout>

    <Button
        android:id="@+id/btnConfirmarReprogramacion"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="CONFIRMAR CAMBIO"
        android:backgroundTint="#458890"
        android:textSize="16sp"
        android:textStyle="bold"/>

</LinearLayout>