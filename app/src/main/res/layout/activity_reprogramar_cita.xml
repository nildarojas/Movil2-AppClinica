<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F2F5"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Reprogramar Cita"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#458890"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="30dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Seleccione Nuevo Médico:"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:layout_marginBottom="8dp" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp">

        <Spinner
            android:id="@+id/spnMedicosReprogramar"
            android:layout_width="match_parent"
            android:layout_height="50dp" />
    </FrameLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Seleccione Nuevo Horario Disponible:"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:layout_marginBottom="8dp" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp">

        <Spinner
            android:id="@+id/spnHorariosReprogramar"
            android:layout_width="match_parent"
            android:layout_height="50dp" />
    </FrameLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConfirmarReprogramacion"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="CONFIRMAR REPROGRAMACIÓN"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#458890"
        app:cornerRadius="8dp" />

</LinearLayout>